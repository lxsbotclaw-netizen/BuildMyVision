# Neon Postgres Verbindungs-URL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Resend API Key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# E-Mail-Absender (muss in Resend verifiziert sein)
EMAIL_FROM=noreply@buildmyvision.de

# Versteckte Empfaenger-E-Mail fuer Benachrichtigungen
CONTACT_EMAIL=kontakt@example.com

# Basis-URL der Anwendung (fuer Token-Links in E-Mails)
NEXT_PUBLIC_BASE_URL=https://buildmyvision.de

# Token-Gueltigkeitsdauer in Stunden
TOKEN_EXPIRY_HOURS=24
